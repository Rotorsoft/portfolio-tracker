{
  "name": "@rotorsoft/portfolio-tracker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">=10.32.1"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "typecheck": "npx tsc --noEmit --project tsconfig.json",
    "dev": "pnpm -F @rotorsoft/portfolio-tracker-app dev:api & pnpm -F @rotorsoft/portfolio-tracker-app dev:client",
    "start": "pnpm -F @rotorsoft/portfolio-tracker-app start",
    "backup": "./scripts/backup-events.sh",
    "restore": "./scripts/restore-events.sh"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "csv": "^6.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
